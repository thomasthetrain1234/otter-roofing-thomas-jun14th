---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import { PHONE_DISPLAY, PHONE_TEL } from '../config';

const faqs = [
  {
    q: 'How long does a roof replacement take?',
    a: 'Most residential shingle replacements take one to two days once materials are on site. Bigger roofs, metal, and tile can run longer. Mark gives you a real schedule before work starts and tells you immediately if weather pushes it.',
  },
  {
    q: 'Should I file an insurance claim or pay out of pocket?',
    a: 'It depends on the damage, your policy, and your deductible. That is exactly what the free video inspection answers. If the damage looks like a covered loss, Mark walks you through the claim. If it does not, he says so and gives you a straight quote instead.',
  },
  {
    q: 'What happens if my insurance claim gets denied?',
    a: 'You owe nothing. The contingency agreement only commits you to Otter Roofing if the insurance company approves a replacement. If they say no, Mark shakes your hand and you part ways with zero cost.',
  },
  {
    q: 'Shingle, metal, or tile: which is right for my house?',
    a: 'Architectural shingle is the workhorse for most Jacksonville homes: strong wind ratings and the best cost per year of life. Metal costs more up front but lasts decades longer and handles coastal weather well. Tile suits specific home styles and needs a structure that can carry the weight. Mark walks you through real numbers for your roof, not a sales script.',
  },
  {
    q: 'Do you do commercial roofs?',
    a: 'The focus is residential, but yes. If you manage a commercial property, call and Mark will take a look and quote it honestly.',
  },
  {
    q: 'What areas do you serve?',
    a: 'Jacksonville and the surrounding Northeast Florida communities. If you are nearby and not sure, call. Worst case, Mark points you to someone good.',
  },
  {
    q: 'Is the inspection really free?',
    a: 'Yes. Every job starts with a free video inspection, whether or not you hire Otter Roofing. You get the footage and an honest read on your roof either way.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Base
  title="Roof Replacement & Roof Repair in Jacksonville, FL | Otter Roofing"
  description="Roof replacement (shingle, metal, tile) and roof repair in Jacksonville, FL. Free video inspections, honest quotes, and insurance claims guided start to finish. If the claim is denied, you owe nothing."
  extraSchema={[faqSchema]}
>
  <!-- PAGE INTRO -->
  <section class="section page-hero">
    <div class="container">
      <span class="kicker">Services</span>
      <h1>Roofing for Jacksonville homes, done by the owner</h1>
      <p class="section-intro">
        Otter Roofing handles residential roof replacements and repairs across
        Jacksonville and the surrounding area. Every job starts the same way:
        Mark climbs your roof, records a video inspection, and shows you
        exactly what he sees. Then you decide.
      </p>
      <div class="cta-cluster">
        <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark</a>
        <div>
          <p class="phone-caption">Call or text</p>
          <a class="phone-plain" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ROOF REPLACEMENT -->
  <section class="section section--tan" id="replacement" aria-labelledby="replacement-heading">
    <div class="container">
      <span class="kicker">Roof Replacement</span>
      <h2 id="replacement-heading">A new roof, managed by one person</h2>
      <p class="section-intro">
        Full tear-off, clean install, full cleanup. Mark orders the materials,
        schedules the crew, supervises the install, and walks the finished roof
        with you. One point of contact from the first phone call to the final
        nail.
      </p>

      <div class="material-grid">
        <article class="card" id="shingle">
          <h3>Shingle</h3>
          <p>
            The specialty. Architectural shingles are the right answer for most
            Jacksonville homes: strong wind ratings for storm season, a wide
            range of colors, and the best value per year of roof life. Mark has
            run shingle replacements end to end since his restoration days, and
            it is the system he knows inside out.
          </p>
          <p>
            Every shingle replacement includes new underlayment, flashing, and
            ridge venting where the roof needs it. No reusing tired components
            under a new surface.
          </p>
        </article>
        <article class="card" id="metal" data-small>
          <h3>Metal</h3>
          <p>
            Higher cost up front, decades more life. Metal stands up well to
            coastal sun and wind, sheds rain fast, and can drop cooling bills.
            If you plan to stay in your home long term, it is worth a serious
            look. Mark will give you the honest math on both options.
          </p>
        </article>
        <article class="card" id="tile" data-small>
          <h3>Tile</h3>
          <p>
            The right fit for certain home styles, and a system that demands
            careful installation. Tile is heavy, so the structure has to be up
            to it. If tile suits your house, Mark will tell you. If it does
            not, he will tell you that too.
          </p>
        </article>
      </div>

      <div class="cta-cluster">
        <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark about a replacement</a>
        <a class="phone-plain" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
      </div>
    </div>
  </section>

  <!-- ROOF REPAIRS -->
  <section class="section" id="repairs" aria-labelledby="repairs-heading">
    <div class="container">
      <span class="kicker">Roof Repairs</span>
      <h2 id="repairs-heading">Small jobs, taken seriously</h2>
      <p class="section-intro">
        Storm damage, leaks, missing shingles, cracked flashing, and the fixes
        a lot of companies will not bother with. Repairs are how Mark earns
        trust in a neighborhood: do the small job right, and you become the
        person they call when the big one comes. He treats a repair with the
        same attention as a full replacement, because it is the same roof over
        the same family.
      </p>
      <div class="cta-cluster">
        <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark about a repair</a>
        <a class="phone-plain" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
      </div>
    </div>
  </section>

  <!-- INSURANCE CLAIMS -->
  <section class="section section--slate" id="insurance" aria-labelledby="insurance-heading">
    <div class="container">
      <div class="insurance-layout">
        <div class="insurance-copy">
          <span class="kicker">Insurance Claims</span>
          <h2 id="insurance-heading">If your claim gets denied, you owe nothing</h2>
          <p class="section-intro insurance-intro">
            Here is the deal, in plain English. If Mark inspects your roof and
            believes your insurance company is likely to cover it, you sign a
            contingency agreement. That means he guides your entire claim: the
            paperwork, the documentation, the phone calls, and he stands on your
            roof next to the adjuster at the inspection to advocate for you.
          </p>
          <p class="section-intro insurance-intro">
            You only commit to Otter Roofing as your contractor if the insurance
            company approves the claim for a replacement. If they say no, Mark
            shakes your hand and walks away. No fee, no invoice, no fine print.
            That is the whole agreement.
          </p>
        </div>
        <ul class="promise-list">
          <li>Free video inspection first, so you see the damage yourself</li>
          <li>Honest read on whether a claim is even worth filing</li>
          <li>Mark attends the adjuster's inspection in person</li>
          <li>You owe nothing if the claim is denied</li>
        </ul>
      </div>
      <div class="cta-cluster insurance-cta">
        <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark about your claim</a>
        <div>
          <p class="phone-caption phone-caption--light">Call or text</p>
          <a class="phone-plain phone-plain--light" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OUT OF POCKET -->
  <section class="section" id="out-of-pocket" aria-labelledby="oop-heading">
    <div class="container">
      <span class="kicker">Paying Out of Pocket</span>
      <h2 id="oop-heading">Inspect. Quote. You decide.</h2>
      <p class="section-intro">
        Not every roof is an insurance job, and Mark will never pretend yours
        is to make a sale. If you are paying out of pocket, the process is
        simple: free video inspection, a clear written quote with pricing
        explained line by line, and time to think it over. You bite or you do
        not. Either way, you keep the inspection footage and the honest
        assessment.
      </p>
      <div class="cta-cluster">
        <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark, get a quote</a>
        <a class="phone-plain" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--tan" id="faq" aria-labelledby="faq-heading">
    <div class="container">
      <span class="kicker">Questions</span>
      <h2 id="faq-heading">Straight answers to common questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Not sure what your roof needs?"
    text="That is what the free video inspection is for. Call Mark and find out."
  />
</Base>

<style>
  .page-hero h1 {
    max-width: 22ch;
  }

  .material-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2.5rem;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    transition: gap 0.3s ease;
  }

  /* Mobile: shingle full-width with slate bar */
  .material-grid #shingle {
    grid-column: 1 / -1;
    border-top-color: var(--slate);
  }

  @media (min-width: 900px) {
    .material-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, auto);
    }

    /* Default: shingle big left (slate bar), metal/tile tiles (brick bar) */
    .material-grid #shingle { grid-column: 1; grid-row: 1 / 3; border-top-color: var(--slate); }
    .material-grid #metal   { grid-column: 2; grid-row: 1;     border-top-color: var(--brick); }
    .material-grid #tile    { grid-column: 2; grid-row: 2;     border-top-color: var(--brick); }

    /* Metal featured: metal → left big (slate), shingle → right top (brick) */
    .material-grid:has(#metal[data-featured]) #shingle { grid-column: 2; grid-row: 1; border-top-color: var(--brick); }
    .material-grid:has(#metal[data-featured]) #metal   { grid-column: 1; grid-row: 1 / 3; border-top-color: var(--slate); }
    .material-grid:has(#metal[data-featured]) #tile    { grid-column: 2; grid-row: 2; }

    /* Tile featured: tile → left big (slate), shingle → right top (brick) */
    .material-grid:has(#tile[data-featured]) #shingle { grid-column: 2; grid-row: 1; border-top-color: var(--brick); }
    .material-grid:has(#tile[data-featured]) #metal   { grid-column: 2; grid-row: 2; }
    .material-grid:has(#tile[data-featured]) #tile    { grid-column: 1; grid-row: 1 / 3; border-top-color: var(--slate); }

    /* Dim the tiles when a non-default card is featured */
    .material-grid:has(#metal[data-featured]) #shingle,
    .material-grid:has(#metal[data-featured]) #tile,
    .material-grid:has(#tile[data-featured]) #shingle,
    .material-grid:has(#tile[data-featured]) #metal {
      opacity: 0.7;
      transition: opacity 0.3s ease;
    }

    /* Tile cards: cursor indicates they're interactive */
    .material-grid #metal,
    .material-grid #tile {
      cursor: pointer;
    }
  }

  .material-grid .card p + p {
    margin-top: 1rem;
  }

  /* Smaller type when a card occupies the compact right-column position */
  @media (min-width: 900px) {
    .material-grid [data-small] h3 {
      font-size: 1.05rem;
    }
    .material-grid [data-small] p {
      font-size: 0.95rem;
      line-height: 1.5;
    }
  }

  /* Insurance section: two-column layout */
  .insurance-layout {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 900px) {
    .insurance-layout {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
  }

  /* Slightly tighter body text inside the two-col layout */
  .insurance-intro {
    font-size: var(--text-base);
  }

  /* CTA centered below both columns */
  .insurance-cta {
    justify-content: center;
    margin-top: 3rem;
  }

  .promise-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.75rem;
  }

  .promise-list li {
    position: relative;
    padding-left: 2.75rem;
    color: var(--cream);
    font-size: var(--text-lg);
    font-weight: 600;
    opacity: 0;
    transform: translateX(18px);
    transition: opacity 0.78s ease, transform 0.78s ease;
  }

  .promise-list.is-visible li:nth-child(1) { transition-delay: 0.05s; }
  .promise-list.is-visible li:nth-child(2) { transition-delay: 0.57s; }
  .promise-list.is-visible li:nth-child(3) { transition-delay: 1.09s; }
  .promise-list.is-visible li:nth-child(4) { transition-delay: 1.61s; }

  .promise-list.is-visible li {
    opacity: 1;
    transform: translateX(0);
  }

  .promise-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.1em;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--tan);
    color: var(--slate);
    font-size: 1rem;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .phone-caption--light {
    color: var(--tan);
  }

  /* FAQ accordion: native details/summary, no JS, keyboard accessible */
  .faq-list {
    margin-top: 2.5rem;
    display: grid;
    gap: 1rem;
    max-width: 50rem;
  }

  .faq-item {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: 0;
    overflow: hidden;
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    min-height: 3.25rem;
    padding: 1.1rem 1.5rem;
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--slate);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--brick);
    transition: transform 0.15s ease;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    padding: 0 1.5rem 1.4rem;
  }
</style>

<script>
  // --- Material grid: FLIP position-swap animation ---
  // Cursor zone detection uses fixed grid coords (not card-level events) to
  // avoid mouseenter/mouseleave loops when cards reposition under the cursor.
  const grid    = document.querySelector('.material-grid') as HTMLElement | null;
  const shingle = document.getElementById('shingle') as HTMLElement | null;
  const metal   = document.getElementById('metal')   as HTMLElement | null;
  const tile    = document.getElementById('tile')    as HTMLElement | null;

  let currentFeatured: string | null = null;
  let pendingFeatured: string | null | undefined = undefined;
  let animating = false;

  function applyFeatured(id: string | null) {
    currentFeatured = id;
    metal?.removeAttribute('data-featured');
    tile?.removeAttribute('data-featured');
    [shingle, metal, tile].forEach(c => c?.removeAttribute('data-small'));

    if (id === 'metal') {
      metal?.setAttribute('data-featured', '');
      shingle?.setAttribute('data-small', '');
      tile?.setAttribute('data-small', '');
    } else if (id === 'tile') {
      tile?.setAttribute('data-featured', '');
      shingle?.setAttribute('data-small', '');
      metal?.setAttribute('data-small', '');
    } else {
      metal?.setAttribute('data-small', '');
      tile?.setAttribute('data-small', '');
    }
  }

  function setFeatured(id: string | null) {
    if (id === currentFeatured) return;
    if (animating) { pendingFeatured = id; return; }
    animating = true;

    const cards = [shingle, metal, tile].filter((c): c is HTMLElement => c !== null);

    // FIRST: snapshot each card's position and opacity before anything changes
    const firsts = cards.map(c => ({
      rect:    c.getBoundingClientRect(),
      opacity: getComputedStyle(c).opacity,
    }));

    // Swap the grid layout (DOM changes, cards jump to new positions)
    applyFeatured(id);

    // LAST: snapshot new positions
    const lasts = cards.map(c => c.getBoundingClientRect());

    // INVERT: push each card back to where it came from using transforms
    cards.forEach((card, i) => {
      const f = firsts[i].rect;
      const l = lasts[i];
      const sx = l.width  ? f.width  / l.width  : 1;
      const sy = l.height ? f.height / l.height : 1;
      card.style.transformOrigin = '0 0';
      card.style.transition      = 'none';
      card.style.transform       = `translate(${f.left - l.left}px, ${f.top - l.top}px) scale(${sx}, ${sy})`;
      card.style.opacity         = firsts[i].opacity;
      card.style.zIndex          = '2';
    });

    // Force reflow so the browser registers the inverted state before animating
    void grid?.offsetHeight;

    // Target opacity for each card in the new state
    function targetOpacity(cardId: string): string {
      if (id === null) return '1';
      return cardId === id ? '1' : '0.7';
    }

    // PLAY: animate each card from its inverted position to its natural position
    const dur  = 420;
    const ease = 'cubic-bezier(0.4, 0, 0.2, 1)';
    cards.forEach(card => {
      card.style.transition = `transform ${dur}ms ${ease}, opacity ${dur}ms ${ease}`;
      card.style.transform  = '';
      card.style.opacity    = targetOpacity(card.id);
    });

    setTimeout(() => {
      cards.forEach(card => {
        card.style.transition      = '';
        card.style.transform       = '';
        card.style.transformOrigin = '';
        card.style.opacity         = '';
        card.style.zIndex          = '';
      });
      animating = false;
      if (pendingFeatured !== undefined) {
        const next = pendingFeatured;
        pendingFeatured = undefined;
        setFeatured(next);
      }
    }, dur + 20);
  }

  // Initialise: metal and tile start in the small positions
  applyFeatured(null);

  if (grid) {
    grid.addEventListener('pointermove', (e) => {
      const rect = grid.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      // Only trigger when cursor is in the right half (where Metal/Tile live)
      if (x > rect.width * 0.5) {
        setFeatured(y < rect.height * 0.5 ? 'metal' : 'tile');
      }
    });

    grid.addEventListener('mouseleave', () => setFeatured(null));
  }

  // --- Promise list: reveal bullets one at a time on scroll ---
  const promiseList = document.querySelector<HTMLElement>('#insurance .promise-list');
  if (promiseList) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    observer.observe(promiseList);
  }

  // --- FAQ: open on hover, close on mouseleave ---
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(item => {
    item.addEventListener('mouseenter', () => { item.open = true; });
    item.addEventListener('mouseleave', () => { item.open = false; });
  });
</script>
