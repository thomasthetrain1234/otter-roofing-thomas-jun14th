---
import { PHONE_DISPLAY, PHONE_TEL } from '../config';

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Otter Roofing home">
      <img src="/logo.png" alt="Otter Roofing LLC logo" width="650" height="850" />
    </a>

    <nav aria-label="Main navigation">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={current === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a class="phone-plain header-phone" href={`tel:${PHONE_TEL}`}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        {PHONE_DISPLAY}
      </a>
      <a class="btn btn--primary" href={`tel:${PHONE_TEL}`}>Talk to Mark</a>
    </div>
  </div>
</header>

<script>
  // Toggles the elevated/shrunk treatment once the page scrolls.
  const header = document.querySelector('.site-header');
  if (header) {
    const update = () => header.classList.toggle('is-scrolled', window.scrollY > 12);
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 244, 238, 0.92); /* --cream at 92% for the blur */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(46, 62, 66, 0.12);
    transition: box-shadow 0.2s ease;
  }

  /* Brand accent stripe */
  .site-header::before {
    content: '';
    display: block;
    height: 4px;
    background: linear-gradient(90deg, var(--brick) 0%, var(--brick) 60%, var(--tan) 60%, var(--tan) 100%);
  }

  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(46, 62, 66, 0.1);
  }

  .header-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    padding-block: 0.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    margin-right: auto;
  }

  .brand img {
    display: block;
    width: auto;
    height: 4.25rem;
    transition: height 0.2s ease;
  }

  .site-header.is-scrolled .brand img {
    height: 3.5rem;
  }

  .nav-list {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .nav-list a {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.5rem 0.9rem;
    font-weight: 600;
    color: var(--slate);
    text-decoration: none;
    border-radius: var(--radius);
    transition: color 0.2s ease;
  }

  /* Animated underline: scales in from the left on hover, stays for the
     current page. Transform-only so it never shifts layout. */
  .nav-list a::after {
    content: '';
    position: absolute;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.45rem;
    height: 3px;
    border-radius: 2px;
    background: var(--brick);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.2s ease-out;
  }

  .nav-list a:hover {
    color: var(--brick-dark);
  }

  .nav-list a:hover::after {
    transform: scaleX(1);
  }

  .nav-list a[aria-current='page'] {
    color: var(--brick-dark);
  }

  .nav-list a[aria-current='page']::after {
    transform: scaleX(1);
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
  }

  .header-phone svg {
    color: var(--brick);
    flex-shrink: 0;
  }

  /* 375px: brand on row one; nav + phone wrap below, button stays tappable.
     The wrapped header is tall, so it stops being sticky here: pinning it
     would cover a third of a phone screen while scrolling. */
  @media (max-width: 740px) {
    .site-header {
      position: static;
    }

    .site-header.is-scrolled {
      box-shadow: none;
    }

    .header-inner {
      justify-content: center;
      text-align: center;
    }

    .brand {
      margin-right: 0;
      flex-basis: 100%;
      justify-content: center;
    }

    .brand img,
    .site-header.is-scrolled .brand img {
      height: 4.5rem;
    }

    .header-cta {
      flex-basis: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.6rem 1.25rem;
    }
  }
</style>
