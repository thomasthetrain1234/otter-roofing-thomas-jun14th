---
import { PHONE_DISPLAY, PHONE_TEL, BUSINESS_NAME, CITY, STATE } from '../config';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="footer-logo">Otter <span>Roofing</span></p>
      <p>
        Veteran-owned roofing company in {CITY}, {STATE}. Roof replacements and
        repairs, handled personally by a licensed contractor.
      </p>
      <p class="badge">Veteran-Owned &amp; Operated</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <h2>Pages</h2>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/services#insurance">Insurance Claims</a></li>
        <li><a href="/about">About Mark</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h2>Talk to Mark</h2>
      <p class="phone-caption">Call or text, he answers</p>
      <a class="phone-plain phone-plain--light" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
      <p class="footer-area">Serving {CITY} and surrounding Northeast Florida communities.</p>
    </div>
  </div>

  <div class="container footer-legal">
    <p>&copy; {year} {BUSINESS_NAME}. Licensed Roofing Contractor, {CITY}, {STATE}.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--slate-deep);
    color: var(--cream);
    padding-block: 3.5rem 1.5rem;
  }

  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }

  .footer-logo span {
    color: var(--tan);
  }

  .footer-brand p {
    margin-bottom: 1rem;
  }

  .site-footer h2 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tan);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
  }

  .footer-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    color: var(--cream);
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--tan);
    text-decoration: underline;
  }

  .footer-contact .phone-caption {
    color: var(--tan);
  }

  .footer-area {
    margin-top: 1rem;
    font-size: 1rem;
    color: rgba(247, 244, 238, 0.8);
  }

  .footer-legal {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(247, 244, 238, 0.18);
    font-size: 0.95rem;
    color: rgba(247, 244, 238, 0.75);
  }
</style>
