---
import '@fontsource/alfa-slab-one';
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  SITE_URL,
  BUSINESS_NAME,
  OWNER_NAME,
  PHONE_DISPLAY,
  CITY,
  STATE,
} from '../config';

interface Props {
  title: string;
  description: string;
  /** Extra JSON-LD blocks (e.g. FAQPage on the services page) */
  extraSchema?: object[];
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description,
  extraSchema = [],
  hideHeader = false,
  hideFooter = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE_URL).href.replace(/\/$/, '') || SITE_URL;

/*
 * RoofingContractor schema on every page. Telephone uses the placeholder
 * constant until the real number lands (single swap in src/config.ts).
 * OG image: replace /assets/og-cover.png with the real branded card,
 * 1200x630. See ASSETS.md.
 */
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  '@id': `${SITE_URL}/#business`,
  name: BUSINESS_NAME,
  url: SITE_URL,
  telephone: PHONE_DISPLAY,
  image: `${SITE_URL}/assets/og-cover.png`,
  logo: `${SITE_URL}/logo.png`,
  founder: {
    '@type': 'Person',
    name: OWNER_NAME,
  },
  areaServed: {
    '@type': 'City',
    name: `${CITY}, ${STATE}`,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: CITY,
    addressRegion: STATE,
    addressCountry: 'US',
  },
  description:
    'Veteran-owned roofing company in Jacksonville, Florida. Roof replacements (shingle, metal, tile) and roof repairs by a licensed contractor who personally inspects, manages, and answers the phone for every job.',
  slogan: 'One number. One roofer. Start to finish.',
};

const schemaBlocks = [businessSchema, ...extraSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BUSINESS_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE_URL}/assets/og-cover.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/assets/og-cover.png`} />

    {schemaBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    {!hideHeader && <Header />}
    <main id="main">
      <slot />
    </main>
    {!hideFooter && <Footer />}
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    background: var(--slate);
    color: var(--cream);
    padding: 0.75rem 1.25rem;
    font-weight: 700;
    border-radius: 0 0 var(--radius) 0;
  }

  .skip-link:focus {
    left: 0;
  }
</style>
